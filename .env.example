# ╔══════════════════════════════════════════════════════╗
# ║          ميزان  ·  MIZAN Configuration               ║
# ║      Copy to .env and fill in your values            ║
# ╚══════════════════════════════════════════════════════╝

# ===== AI PROVIDERS (at least one required) =====
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=                        # Optional
OPENROUTER_API_KEY=                    # Optional — access 300+ models via openrouter.ai

# ===== MODEL =====
# LLM_PROVIDER=                        # auto-detect | anthropic | openrouter | openai | ollama
DEFAULT_MODEL=claude-sonnet-4-20250514
# OpenRouter models: anthropic/claude-sonnet-4, google/gemini-2.0-flash, meta-llama/llama-4-scout, etc.

# ===== SYSTEM =====
SECRET_KEY=change-this-to-a-secure-random-string
DEBUG=false
LOG_LEVEL=INFO

# ===== SERVER =====
HOST=0.0.0.0
PORT=8000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ===== PRODUCTION DEPLOYMENT =====
# DOMAIN=mizan.example.com          # Your domain (for SSL)
# HTTP_PORT=80                      # Public HTTP port
# HTTPS_PORT=443                    # Public HTTPS port
# SSL_EMAIL=admin@example.com       # Email for Let's Encrypt
# NGINX_CONF=nginx-nossl.conf       # nginx-nossl.conf or nginx.conf (SSL)

# ===== DATABASE =====
DB_PATH=data/mizan.db

# ===== LOCAL AI (Optional) =====
OLLAMA_URL=http://localhost:11434

# ===== CHANNELS (Optional) =====
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=
SLACK_APP_TOKEN=
WHATSAPP_TOKEN=

# ===== EMAIL (Optional) =====
EMAIL_HOST=imap.gmail.com
EMAIL_USER=
EMAIL_PASSWORD=
