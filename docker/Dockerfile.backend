FROM python:3.12-slim

WORKDIR /app

# Install system deps
RUN apt-get update && apt-get install -y \
    curl git build-essential \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY . .

# Create data and plugins directories
RUN mkdir -p /data plugins

EXPOSE 8000

# Entrypoint script for env validation and graceful shutdown
RUN printf '#!/bin/bash\n\
set -e\n\
echo "MIZAN Backend — validating environment..."\n\
MISSING=""\n\
if [ -z "${SECRET_KEY:-}" ]; then\n\
    MISSING="$MISSING SECRET_KEY"\n\
fi\n\
if [ -z "${ANTHROPIC_API_KEY:-}" ] && [ -z "${OPENAI_API_KEY:-}" ] && [ -z "${OLLAMA_URL:-}" ]; then\n\
    echo "WARNING: No LLM provider configured (ANTHROPIC_API_KEY, OPENAI_API_KEY, or OLLAMA_URL)"\n\
fi\n\
if [ -n "$MISSING" ]; then\n\
    echo "ERROR: Missing required environment variables:$MISSING"\n\
    exit 1\n\
fi\n\
echo "Environment validated. Starting MIZAN backend..."\n\
exec "$@"\n' > /entrypoint.sh && chmod +x /entrypoint.sh

ENTRYPOINT ["/entrypoint.sh"]
CMD ["uvicorn", "api.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]
