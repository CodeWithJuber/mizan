# ═══════════════════════════════════════════════════════════════
# MIZAN Backend — Production Dockerfile
# Multi-stage build for minimal image size
# ═══════════════════════════════════════════════════════════════

FROM python:3.12-slim AS builder

WORKDIR /build

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --no-cache-dir --prefix=/install -r requirements.txt

# ── Production stage ──
FROM python:3.12-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    && rm -rf /var/lib/apt/lists/* \
    && groupadd -r mizan && useradd -r -g mizan -d /app -s /sbin/nologin mizan

COPY --from=builder /install /usr/local

COPY . .

RUN mkdir -p /data plugins && chown -R mizan:mizan /app /data

# Entrypoint script for env validation and graceful shutdown
COPY <<'ENTRYPOINT' /entrypoint.sh
#!/bin/bash
set -e

# ── Environment variable validation ──
echo "MIZAN Backend (production) — validating environment..."
MISSING=""

if [ -z "$SECRET_KEY" ]; then
    MISSING="$MISSING SECRET_KEY"
fi

if [ -z "$ANTHROPIC_API_KEY" ] && [ -z "$OPENAI_API_KEY" ] && [ -z "$OLLAMA_URL" ]; then
    echo "WARNING: No LLM provider configured (ANTHROPIC_API_KEY, OPENAI_API_KEY, or OLLAMA_URL)"
fi

if [ -n "$MISSING" ]; then
    echo "ERROR: Missing required environment variables:$MISSING"
    exit 1
fi

echo "Environment validated. Starting MIZAN backend..."

# ── Graceful shutdown: exec replaces shell so PID 1 receives SIGTERM ──
exec "$@"
ENTRYPOINT
RUN chmod +x /entrypoint.sh && chown mizan:mizan /entrypoint.sh

USER mizan

EXPOSE 8000

HEALTHCHECK --interval=30s --timeout=10s --start-period=15s --retries=3 \
    CMD curl -f http://localhost:8000/ || exit 1

ENTRYPOINT ["/entrypoint.sh"]
CMD ["uvicorn", "api.main:app", "--host", "0.0.0.0", "--port", "8000", "--workers", "4", "--proxy-headers", "--forwarded-allow-ips", "*"]
